# Docker Compose environment (root)
# For local backend dev, use backend/.env instead.
POSTGRES_DB=teencare
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Backend container
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/teencare?schema=public

# Frontend container/browser
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
